FROM golang:1.25-bookworm AS build

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/screenshotd ./cmd/screenshotd

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium \
    ca-certificates \
    fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

ENV CHROMIUM_PATH=/usr/bin/chromium
ENV HOME=/tmp

COPY --from=build /out/screenshotd /usr/local/bin/screenshotd

EXPOSE 8088
USER nobody

ENTRYPOINT ["/usr/local/bin/screenshotd"]
